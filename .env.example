# ──────────────────────────────────────────
# web.seitig — Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle
# die Werte aus.
# ──────────────────────────────────────────

# MongoDB-Verbindung (z.B. MongoDB Atlas)
MONGODB_URI=mongodb+srv://<benutzer>:<passwort>@<cluster>.mongodb.net/<datenbankname>?retryWrites=true&w=majority

# SMTP-Server für E-Mail-Versand (NodeMailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@example.com
SMTP_PASS=dein-smtp-passwort

# E-Mail-Adresse, an die neue Leads gesendet werden
ADMIN_EMAIL=info@example.com

# Geheimer Schlüssel für den CRM-Zugang
# Ändere diesen Wert auf etwas Sicheres!
CRM_ADMIN_KEY=webseitig-admin-2025

# Session-Secret für Cookie-Signierung (mind. 32 zufällige Zeichen)
SESSION_SECRET=aendere-mich-auf-einen-langen-zufaelligen-wert
